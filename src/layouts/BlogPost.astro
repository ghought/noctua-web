---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readTime?: string;
}

const { title, description, pubDate, tags, readTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Base title={`${title} — Noctua`} description={description}>
  <main>
    <!-- Blog post header -->
    <header class="post-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/blog">← JOURNAL</a>
        </nav>
        <div class="post-meta">
          <span class="mono dim">{formattedDate}</span>
          {readTime && <span class="mono dim sep">·</span>}
          {readTime && <span class="mono dim">{readTime}</span>}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag mono">{tag}</span>)}
          </div>
        )}
        <hr class="hairline" style="margin-top: 2.5rem;" />
      </div>
    </header>

    <!-- Post body -->
    <article class="container post-body">
      <div class="prose">
        <slot />
      </div>

      <!-- Post footer CTA -->
      <aside class="post-cta frame-box">
        <p class="mono gold" style="margin-bottom: 0.75rem;">NOCTUA · DREAM JOURNAL</p>
        <p style="font-family: var(--font-slab); font-size: 1.375rem; color: var(--text); line-height: 1.3; margin-bottom: 1rem;">
          Interpret your own dreams — through the framework that resonates with you.
        </p>
        <p style="color: var(--text-soft); font-size: 0.9375rem; margin-bottom: 1.5rem;">
          Jungian, Cognitive, or Spiritual — three interpretations free every month. No account required.
        </p>
        <div class="store-badges">
          <a href="#app-store" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M11.182 8.013c-.02-2.05 1.674-3.04 1.75-3.09-0.954-1.394-2.44-1.585-2.97-1.608-1.263-.128-2.47.744-3.11.744-.64 0-1.624-.727-2.673-.707-1.374.02-2.646.8-3.354 2.027-1.43 2.48-.366 6.15 1.028 8.163.683.99 1.496 2.1 2.564 2.06 1.03-.04 1.42-.663 2.664-.663 1.245 0 1.594.663 2.685.641 1.107-.018 1.807-1.005 2.482-1.998a8.87 8.87 0 001.13-2.313c-.024-.01-2.166-.833-2.19-3.256z" fill="currentColor"/>
              <path d="M9.144 2.366C9.7 1.687 10.074.76 9.968-.18c-.79.042-1.747.527-2.31 1.19-.507.587-.952 1.524-.833 2.422.879.07 1.776-.448 2.319-1.066z" fill="currentColor"/>
            </svg>
            App Store
          </a>
          <a href="#google-play" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M1.5 1.1L9.15 8 1.5 14.9A1 1 0 011 14V2a1 1 0 01.5-.9z" fill="currentColor" opacity=".6"/>
              <path d="M11.35 5.85L3.2 1.4l6.3 6.3-4.2 4.2 6.05-3.45a1 1 0 000-1.7z" fill="currentColor"/>
              <path d="M12.65 6.6l-1.3-.75-1.85 1.85 1.85 1.85 1.3-.75a1 1 0 000-2.2z" fill="currentColor" opacity=".8"/>
            </svg>
            Google Play
          </a>
        </div>
      </aside>
    </article>
  </main>
</Base>

<style>
  .post-header {
    padding-top: 6rem;
    padding-bottom: 3rem;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
  }
  .breadcrumb a { transition: opacity 0.15s; }
  .breadcrumb a:hover { opacity: 0.7; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .sep { opacity: 0.4; }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    max-width: 820px;
    margin-bottom: 1.25rem;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--text-soft);
    max-width: 640px;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--rule);
    color: var(--text-dim);
    font-size: 0.625rem;
  }

  .post-body {
    padding-top: 3rem;
    padding-bottom: 6rem;
  }

  .post-cta {
    margin-top: 4rem;
    max-width: var(--max-w-prose);
    padding: 2rem;
  }
</style>

---
import Base from '../layouts/Base.astro';
import Constellation from '../components/Constellation.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base title="Noctua — Dream Journal & Interpretation">
  <main>

    <!-- ── HERO ────────────────────────────────────────────────── -->
    <section class="hero" id="top">
      <Constellation opacity={0.7} />
      <div class="container hero-inner">
        <div class="hero-eyebrow mono gold">
          DREAM JOURNAL · INTERPRETATION · PATTERNS
        </div>
        <h1 class="hero-headline">
          Your dreams are<br />
          <em>trying to tell<br />you something.</em>
        </h1>
        <p class="hero-sub">
          Noctua interprets what you dream — through Jungian psychology,
          cognitive neuroscience, or spiritual tradition — and reveals
          the patterns your sleeping mind returns to night after night.
        </p>
        <div class="store-badges hero-badges" id="download">
          <a href="#app-store-placeholder" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M11.182 8.013c-.02-2.05 1.674-3.04 1.75-3.09-.954-1.394-2.44-1.585-2.97-1.608-1.263-.128-2.47.744-3.11.744-.64 0-1.624-.727-2.673-.707-1.374.02-2.646.8-3.354 2.027-1.43 2.48-.366 6.15 1.028 8.163.683.99 1.496 2.1 2.564 2.06 1.03-.04 1.42-.663 2.664-.663 1.245 0 1.594.663 2.685.641 1.107-.018 1.807-1.005 2.482-1.998a8.87 8.87 0 001.13-2.313c-.024-.01-2.166-.833-2.19-3.256z" fill="currentColor"/>
              <path d="M9.144 2.366C9.7 1.687 10.074.76 9.968-.18c-.79.042-1.747.527-2.31 1.19-.507.587-.952 1.524-.833 2.422.879.07 1.776-.448 2.319-1.066z" fill="currentColor"/>
            </svg>
            Download on the App Store
          </a>
          <a href="#google-play-placeholder" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M1.5 1.1L9.15 8 1.5 14.9A1 1 0 011 14V2a1 1 0 01.5-.9z" fill="currentColor" opacity=".6"/>
              <path d="M11.35 5.85L3.2 1.4l6.3 6.3-4.2 4.2 6.05-3.45a1 1 0 000-1.7z" fill="currentColor"/>
              <path d="M12.65 6.6l-1.3-.75-1.85 1.85 1.85 1.85 1.3-.75a1 1 0 000-2.2z" fill="currentColor" opacity=".8"/>
            </svg>
            Get it on Google Play
          </a>
        </div>
        <p class="hero-footnote mono dim">
          3 interpretations free every month · No account required to start
        </p>
      </div>
      <div class="hero-scroll-cue" aria-hidden="true">
        <span class="mono dim">SCROLL</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ── NOT A DREAM DICTIONARY ──────────────────────────────── -->
    <section class="section-intro" id="frameworks">
      <div class="container">
        <div class="intro-grid">
          <div class="intro-left">
            <span class="mono gold section-label">THE DIFFERENCE</span>
            <h2 class="intro-heading">
              Not a dream<br />dictionary.
            </h2>
          </div>
          <div class="intro-right">
            <p>
              Dream dictionaries give you the same answer regardless of
              who you are, what's happening in your life, or which
              tradition resonates with you. They reduce your dreams to
              bullet points.
            </p>
            <p>
              Noctua interprets your specific dream — accounting for the
              details you remember, the emotions that lingered, and the
              framework your intuition leans toward. Three lenses. One dream.
              Genuinely different interpretations.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FRAMEWORKS ─────────────────────────────────────────── -->
    <section class="section-frameworks">
      <div class="container">
        <div class="frameworks-grid">

          <div class="framework-card frame-box">
            <div class="framework-accent" style="background: var(--amethyst)"></div>
            <span class="mono framework-tag" style="color: var(--amethyst)">01 · JUNGIAN</span>
            <h3 class="framework-name">The Unconscious Speaks</h3>
            <p class="framework-desc">
              Archetypes, shadow work, the collective unconscious.
              Your dream figures as messengers from the parts of
              yourself you've been ignoring — the Shadow, the Anima,
              the Self. Interpretation as a path toward individuation.
            </p>
            <div class="framework-footer">
              <span class="mono dim framework-theorist">Carl Jung · 1875–1961</span>
            </div>
          </div>

          <div class="framework-card frame-box">
            <div class="framework-accent" style="background: var(--sapphire)"></div>
            <span class="mono framework-tag" style="color: var(--sapphire)">02 · COGNITIVE</span>
            <h3 class="framework-name">The Brain at Work</h3>
            <p class="framework-desc">
              Memory consolidation, emotional processing, threat
              simulation. What neuroscience actually says your brain
              is doing during sleep — and why the content of your
              dreams reflects the concerns your waking mind can't resolve.
            </p>
            <div class="framework-footer">
              <span class="mono dim framework-theorist">Hobson · Revonsuo · Hartmann</span>
            </div>
          </div>

          <div class="framework-card frame-box">
            <div class="framework-accent" style="background: var(--gold)"></div>
            <span class="mono framework-tag" style="color: var(--gold)">03 · SPIRITUAL</span>
            <h3 class="framework-name">The Ancient Language</h3>
            <p class="framework-desc">
              Cross-cultural traditions from Greco-Roman to Hindu,
              Indigenous to Islamic, Biblical to Buddhist. Dreams as
              messages from a source deeper than the ordinary mind —
              interpreted through the tradition that speaks to you.
            </p>
            <div class="framework-footer">
              <span class="mono dim framework-theorist">Global · Timeless</span>
            </div>
          </div>

        </div>

        <p class="frameworks-note">
          <span class="mono dim">EXPLORER TIER ADDS →</span>&nbsp;
          <span style="color: var(--text-soft)">Freudian, Gestalt, and Existential frameworks, plus Comparative mode — see all lenses side by side for the same dream.</span>
        </p>
      </div>
    </section>

    <!-- ── HOW IT WORKS ───────────────────────────────────────── -->
    <section class="section-how" id="how-it-works">
      <div class="container">
        <div class="how-header">
          <span class="mono gold section-label">HOW IT WORKS</span>
          <hr class="hairline how-rule" />
        </div>
        <ol class="how-steps">
          <li class="how-step">
            <span class="mono gold step-num">01</span>
            <div class="step-body">
              <h3 class="step-title">Log</h3>
              <p class="step-desc">
                Write or speak your dream each morning, before the day
                overwrites it. Capture fragments, emotions, anything
                that remains. The app is optimized for the half-awake
                state — minimal friction, large type, no jarring whites.
              </p>
            </div>
          </li>
          <li class="how-step">
            <span class="mono gold step-num">02</span>
            <div class="step-body">
              <h3 class="step-title">Interpret</h3>
              <p class="step-desc">
                Choose your framework. Receive a structured interpretation —
                thematic overview, symbol breakdown, emotional landscape,
                connection to waking life, and reflection prompts to sit with.
                Ask follow-up questions. Push back. The interpretation listens.
              </p>
            </div>
          </li>
          <li class="how-step">
            <span class="mono gold step-num">03</span>
            <div class="step-body">
              <h3 class="step-title">Discover</h3>
              <p class="step-desc">
                Over weeks and months, patterns emerge. Symbols recur.
                Your dream life develops a geography, a cast of recurring
                figures, a set of persistent concerns. Noctua surfaces
                what a single interpretation never could.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ── PATTERN RECOGNITION ────────────────────────────────── -->
    <section class="section-patterns" id="features">
      <div class="container">
        <div class="patterns-grid">
          <div class="patterns-left">
            <span class="mono gold section-label">PATTERN RECOGNITION</span>
            <h2 class="patterns-heading">
              The insight no single<br />dream can give you.
            </h2>
            <p class="patterns-sub">
              A single interpretation is interesting. Six months of
              interpretations reveals something else entirely — what
              your psyche keeps returning to, and why.
            </p>
          </div>
          <div class="patterns-right">
            <div class="feature-list">
              {[
                { label: 'Recurring Symbols', desc: 'Track which symbols appear across dreams — and how their meaning shifts over time.' },
                { label: 'Emotional Arcs', desc: 'A timeline of your dream-emotional landscape: are dreams becoming more anxious? More peaceful?' },
                { label: 'Monthly Insight Reports', desc: 'Auto-generated narrative synthesis: dominant themes, new symbols, what your dreams may be telling you this month.' },
                { label: 'Personal Dream Dictionary', desc: 'Not a generic symbol list. Your own lexicon — built from your dreams, reflecting your personal associations.' },
                { label: 'Life Event Correlations', desc: 'When you tag waking-life context, the app surfaces when dream patterns and life events align.' },
              ].map(f => (
                <div class="feature-item">
                  <div class="feature-dot"></div>
                  <div>
                    <strong class="feature-label">{f.label}</strong>
                    <p class="feature-desc">{f.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PRICING ─────────────────────────────────────────────── -->
    <section class="section-pricing" id="pricing">
      <div class="container">
        <div class="pricing-header">
          <span class="mono gold section-label">PRICING</span>
          <h2 class="pricing-heading">Start free. Go deeper when you're ready.</h2>
        </div>
        <div class="pricing-grid">

          <!-- Free -->
          <div class="pricing-card frame-box">
            <div class="plan-tier mono dim">DREAMER</div>
            <div class="plan-price">
              <span class="price-amount">Free</span>
            </div>
            <p class="plan-tagline">
              Enough to experience one genuinely great interpretation.
            </p>
            <hr class="hairline" style="margin: 1.5rem 0;" />
            <ul class="plan-features">
              {[
                'Log unlimited dreams',
                '3 interpretations per month',
                'Cognitive framework',
                'Basic dream timeline',
              ].map(f => (
                <li class="plan-feature">
                  <span class="feature-check mono gold">—</span>
                  {f}
                </li>
              ))}
            </ul>
            <div class="plan-cta">
              <a href="#download" class="btn-ghost" style="width: 100%; justify-content: center;">
                Download Free
              </a>
            </div>
          </div>

          <!-- Explorer -->
          <div class="pricing-card pricing-card--featured frame-box">
            <div class="plan-badge mono">MOST POPULAR</div>
            <div class="plan-tier mono" style="color: var(--gold)">EXPLORER</div>
            <div class="plan-price">
              <span class="price-amount">$6.99</span>
              <span class="price-period mono dim">/ month</span>
            </div>
            <p class="plan-tagline plan-tagline--featured">
              Or $59.99/year — save 29%.
            </p>
            <hr class="hairline" style="margin: 1.5rem 0; border-color: var(--gold-dim);" />
            <ul class="plan-features">
              {[
                'Unlimited interpretations',
                'All 3 frameworks + Comparative mode',
                'Full pattern recognition',
                'Personal dream dictionary',
                'Monthly insight reports',
                'Voice capture',
                'Guided prompts & follow-up dialogue',
              ].map(f => (
                <li class="plan-feature">
                  <span class="feature-check mono gold">—</span>
                  {f}
                </li>
              ))}
            </ul>
            <div class="plan-cta">
              <a href="#download" class="btn-primary" style="width: 100%; justify-content: center;">
                Start Free Trial →
              </a>
            </div>
          </div>

        </div>

        <p class="pricing-note mono dim">
          Subscriptions managed through the App Store and Google Play. Cancel anytime.
        </p>
      </div>
    </section>

    <!-- ── RECENT POSTS ───────────────────────────────────────── -->
    <section class="section-blog">
      <div class="container">
        <div class="blog-header">
          <div>
            <span class="mono gold section-label">DREAM JOURNAL</span>
            <h2 class="blog-heading">From the archive</h2>
          </div>
          <a href="/blog" class="mono gold blog-all">All posts →</a>
        </div>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-card-meta">
                <span class="mono dim">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                {post.data.readTime && (
                  <span class="mono dim">· {post.data.readTime}</span>
                )}
              </div>
              <h3 class="blog-card-title">{post.data.title}</h3>
              <p class="blog-card-desc">{post.data.description}</p>
              <span class="mono gold blog-read">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── NEWSLETTER ─────────────────────────────────────────── -->
    <section class="section-newsletter" id="newsletter">
      <div class="container">
        <div class="newsletter-inner frame-box">
          <Constellation opacity={0.35} />
          <div class="newsletter-content">
            <NewsletterForm />
          </div>
        </div>
      </div>
    </section>

    <!-- ── FINAL CTA ──────────────────────────────────────────── -->
    <section class="section-final-cta">
      <div class="container final-cta-inner">
        <span class="mono gold section-label">BEGIN TONIGHT</span>
        <h2 class="final-cta-heading">
          Start your<br /><em>dream archive.</em>
        </h2>
        <p class="final-cta-sub">
          The first interpretation is free. No account required.
          Your dreams are already happening — start making sense of them.
        </p>
        <div class="store-badges">
          <a href="#app-store-placeholder" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M11.182 8.013c-.02-2.05 1.674-3.04 1.75-3.09-.954-1.394-2.44-1.585-2.97-1.608-1.263-.128-2.47.744-3.11.744-.64 0-1.624-.727-2.673-.707-1.374.02-2.646.8-3.354 2.027-1.43 2.48-.366 6.15 1.028 8.163.683.99 1.496 2.1 2.564 2.06 1.03-.04 1.42-.663 2.664-.663 1.245 0 1.594.663 2.685.641 1.107-.018 1.807-1.005 2.482-1.998a8.87 8.87 0 001.13-2.313c-.024-.01-2.166-.833-2.19-3.256z" fill="currentColor"/>
              <path d="M9.144 2.366C9.7 1.687 10.074.76 9.968-.18c-.79.042-1.747.527-2.31 1.19-.507.587-.952 1.524-.833 2.422.879.07 1.776-.448 2.319-1.066z" fill="currentColor"/>
            </svg>
            App Store
          </a>
          <a href="#google-play-placeholder" class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M1.5 1.1L9.15 8 1.5 14.9A1 1 0 011 14V2a1 1 0 01.5-.9z" fill="currentColor" opacity=".6"/>
              <path d="M11.35 5.85L3.2 1.4l6.3 6.3-4.2 4.2 6.05-3.45a1 1 0 000-1.7z" fill="currentColor"/>
              <path d="M12.65 6.6l-1.3-.75-1.85 1.85 1.85 1.85 1.3-.75a1 1 0 000-2.2z" fill="currentColor" opacity=".8"/>
            </svg>
            Google Play
          </a>
        </div>
      </div>
    </section>

  </main>
</Base>

<style>
/* ── Hero ──────────────────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-top: 5rem;
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding-top: 5rem;
  padding-bottom: 8rem;
}

.hero-eyebrow {
  margin-bottom: 1.75rem;
  font-size: 0.625rem;
  letter-spacing: 0.2em;
}

.hero-headline {
  font-size: clamp(3rem, 8vw, 6rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: 1.75rem;
  max-width: 820px;
}
.hero-headline em {
  font-style: italic;
  color: var(--gold);
}

.hero-sub {
  font-size: clamp(1rem, 2vw, 1.1875rem);
  color: var(--text-soft);
  max-width: 540px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}

.hero-badges { margin-bottom: 1.25rem; }

.hero-footnote {
  font-size: 0.625rem;
  letter-spacing: 0.12em;
}

.hero-scroll-cue {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.625rem;
}
.hero-scroll-cue .mono { font-size: 0.5625rem; letter-spacing: 0.2em; }
.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--gold-dim), transparent);
}

/* ── Intro ─────────────────────────────────────────────────────── */
.section-intro {
  padding: 6rem 0;
  border-top: 1px solid var(--rule);
}

.intro-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
}
@media (min-width: 768px) {
  .intro-grid { grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: center; }
}

.section-label {
  display: block;
  font-size: 0.625rem;
  letter-spacing: 0.2em;
  margin-bottom: 1rem;
}

.intro-heading {
  font-size: clamp(2.25rem, 5vw, 3.5rem);
  line-height: 1.05;
}

.intro-right p {
  color: var(--text-soft);
  font-size: 1.0625rem;
  line-height: 1.75;
  margin-bottom: 1.25rem;
}
.intro-right p:last-child { margin-bottom: 0; }

/* ── Frameworks ────────────────────────────────────────────────── */
.section-frameworks {
  padding-bottom: 6rem;
}

.frameworks-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-bottom: 2rem;
}
@media (min-width: 768px) {
  .frameworks-grid { grid-template-columns: repeat(3, 1fr); }
}

.framework-card {
  padding: 2rem;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s;
}
.framework-card:hover { border-color: var(--gold-dim); }

.framework-accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  opacity: 0.6;
}

.framework-tag {
  display: block;
  font-size: 0.625rem;
  letter-spacing: 0.16em;
  margin-bottom: 1rem;
}

.framework-name {
  font-family: var(--font-slab);
  font-size: 1.375rem;
  font-weight: 400;
  margin-bottom: 0.875rem;
  line-height: 1.2;
}

.framework-desc {
  color: var(--text-soft);
  font-size: 0.9375rem;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.framework-footer { margin-top: auto; }
.framework-theorist { font-size: 0.625rem; letter-spacing: 0.1em; }

.frameworks-note {
  padding: 1.25rem;
  border: 1px solid var(--rule-soft);
  font-size: 0.9375rem;
}

/* ── How It Works ──────────────────────────────────────────────── */
.section-how {
  padding: 6rem 0;
  border-top: 1px solid var(--rule);
}

.how-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 3.5rem;
}
.how-rule { flex: 1; }

.how-steps {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
}
@media (min-width: 768px) {
  .how-steps { grid-template-columns: repeat(3, 1fr); gap: 2px; }
}

.how-step {
  padding: 2rem;
  border: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
@media (min-width: 768px) {
  .how-step { border-right: none; }
  .how-step:last-child { border-right: 1px solid var(--rule); }
}

.step-num {
  font-size: 0.625rem;
  letter-spacing: 0.2em;
}

.step-title {
  font-family: var(--font-slab);
  font-size: 1.625rem;
  font-weight: 400;
}

.step-desc {
  color: var(--text-soft);
  font-size: 0.9375rem;
  line-height: 1.7;
}

/* ── Patterns ──────────────────────────────────────────────────── */
.section-patterns {
  padding: 6rem 0;
  border-top: 1px solid var(--rule);
}

.patterns-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}
@media (min-width: 900px) {
  .patterns-grid { grid-template-columns: 1fr 1.25fr; gap: 5rem; align-items: start; }
}

.patterns-heading {
  font-size: clamp(2rem, 4vw, 2.875rem);
  margin-bottom: 1.25rem;
  line-height: 1.1;
}
.patterns-sub {
  color: var(--text-soft);
  font-size: 1.0625rem;
  line-height: 1.7;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.feature-item {
  display: flex;
  gap: 1.25rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--rule-soft);
  align-items: flex-start;
}
.feature-item:first-child { border-top: 1px solid var(--rule-soft); }

.feature-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
  margin-top: 0.45rem;
  opacity: 0.7;
}

.feature-label {
  display: block;
  font-family: var(--font-slab);
  font-size: 1.0625rem;
  font-weight: 400;
  color: var(--text);
  margin-bottom: 0.25rem;
}
.feature-desc {
  color: var(--text-soft);
  font-size: 0.875rem;
  line-height: 1.6;
}

/* ── Pricing ───────────────────────────────────────────────────── */
.section-pricing {
  padding: 6rem 0;
  border-top: 1px solid var(--rule);
}

.pricing-header { margin-bottom: 3rem; }
.pricing-heading {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  margin-top: 0.75rem;
}

.pricing-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  max-width: 800px;
}
@media (min-width: 640px) {
  .pricing-grid { grid-template-columns: 1fr 1fr; }
}

.pricing-card {
  padding: 2rem;
  position: relative;
}

.pricing-card--featured {
  border-color: var(--gold-dim);
}

.plan-badge {
  position: absolute;
  top: -1px;
  right: 1.5rem;

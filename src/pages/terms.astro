---
import Base from '../layouts/Base.astro';
---

<Base
  title="Terms of Use — Noctua"
  description="Noctua's terms of use. What the app is, what it isn't, and the agreement between us."
>
  <main class="util-main">
    <div class="container">
      <header class="util-header">
        <nav class="breadcrumb">
          <a href="/" class="mono gold">← NOCTUA</a>
        </nav>
        <span class="mono gold section-label">LEGAL</span>
        <h1 class="util-title">Terms of Use</h1>
        <p class="util-sub">
          The agreement between you and Noctua. Readable in plain language,
          as it should be.
        </p>
        <hr class="hairline" style="margin-top: 2rem;" />
      </header>

      <div class="util-body">
        <div class="redirect-notice frame-box">
          <p class="mono gold" style="margin-bottom: 0.75rem; font-size: 0.625rem; letter-spacing: 0.16em;">FULL TERMS</p>
          <p style="color: var(--text-soft); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 1.5rem;">
            The complete Noctua Terms of Use are published on the app server and kept current there.
            Click below to read them in full.
          </p>
          <a
            href="https://noctua.up.railway.app/terms"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Read the Full Terms of Use →
          </a>
        </div>

        <div class="util-summary">
          <h2>The important bit</h2>
          <p>
            Noctua is a reflection tool — a journal and interpretation aid for personal insight.
            It is not a substitute for professional mental health care.
          </p>
          <ul>
            <li>Noctua is not therapy and does not provide medical or psychological diagnosis.</li>
            <li>If you're experiencing a mental health crisis, please reach out to a qualified professional or crisis line.</li>
            <li>Your dream content belongs to you. We don't own it, sell it, or share it.</li>
            <li>Subscriptions are managed through the App Store or Google Play and governed by their terms.</li>
          </ul>
          <p>
            Questions? Reach us at <a href="mailto:legal@noctua.app">legal@noctua.app</a>.
          </p>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .util-main {
    padding-top: 7rem;
    padding-bottom: 8rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
  }
  .breadcrumb a { transition: opacity 0.15s; }
  .breadcrumb a:hover { opacity: 0.7; }

  .section-label {
    display: block;
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.875rem;
  }

  .util-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
  }

  .util-sub {
    font-size: 1.125rem;
    color: var(--text-soft);
    max-width: 560px;
    line-height: 1.65;
  }

  .util-body {
    padding-top: 3rem;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .redirect-notice { padding: 2rem; }

  .util-summary h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .util-summary p {
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .util-summary ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .util-summary li {
    display: flex;
    gap: 0.875rem;
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.6;
  }
  .util-summary li::before {
    content: '—';
    color: var(--gold);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }
  .util-summary a {
    color: var(--gold);
    text-decoration: underline;
    text-decoration-color: var(--gold-dim);
    text-underline-offset: 3px;
  }
</style>
